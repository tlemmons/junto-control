# Copy to .env (which is gitignored) and fill real values.
# See README for descriptions.

# Required: where the shared-memory MCP server lives.
MCP_URL=http://localhost:8080/mcp

# Required at runtime: the user-tier API key. Server-injected; never commit a real value.
TOM_WEB_API_KEY=

# UI agent identity for memory_start_session.
CLAUDECONTROL_AGENT_NAME=claude-control
CLAUDECONTROL_PROJECT=claudecontrol

# Browser session secret (signs cookies). Generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
SESSION_SECRET=

# Login passphrase the human types in the /login form. v1 single-user model.
LOGIN_PASSPHRASE=

# Bind address for FastAPI/Uvicorn.
HOST=0.0.0.0
PORT=8000

# Logging.
LOG_LEVEL=INFO
